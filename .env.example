# Public (safe to expose to the browser) — used by the anon read clients.
NEXT_PUBLIC_SUPABASE_URL=https://shgdrkrqjnwtlyxcdayp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER-ONLY secret — used by the /admin/review Server Action to write via the
# record_criterion_change RPC. NEVER prefix with NEXT_PUBLIC_. Set in Vercel
# Project → Settings → Environment Variables (and .env.local for local dev).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated allowlist of analyst emails permitted to use /admin/review.
# Must match the email of the GitHub account used to sign in.
ADMIN_EMAILS=you@example.com
