# ============================================
# PUBLIC ENVIRONMENT VARIABLES (safe for browser)
# ============================================
# Supabase public API endpoint
NEXT_PUBLIC_SUPABASE_URL=https://shgdrkrqjnwtlyxcdayp.supabase.co

# Supabase public (anon) API key for read-only client operations
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: MapTiler API key for basemap in network visualizations
# (used on /research/children-of-god-network and /research/twelve-tribes-network)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# ============================================
# SERVER-ONLY SECRETS (NEVER expose to browser)
# ============================================
# Supabase service role key for admin operations
# Used by: /admin/curator, /admin/intake, /admin/review Server Actions
# Set in Vercel → Project Settings → Environment Variables
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub Actions dispatch token for triggering intake-pipeline workflow
# Requires: repo:public_repo, repo:repo_deployment, actions:write scopes
# Used by: /api/cron/run-intake to dispatch cultiness-spectrum/intake-pipeline.yml
GH_DISPATCH_TOKEN=your-github-actions-token

# Random secret for protecting cron routes from unauthorized triggering
# Used by: /api/cron/refresh-network-stats, /api/cron/sync-usaspending, /api/cron/run-intake
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-cron-secret-generated-with-openssl

# Enable paid scoring in intake pipeline (default: false for dry-run)
# Set to 'true' only when ready for real (paid) model API calls
INTAKE_LIVE=false

# ============================================
# ADMIN ACCESS CONFIGURATION
# ============================================
# Comma-separated allowlist of analyst emails permitted to use /admin/* pages
# Must match the email returned by your OAuth provider
# (Google / GitHub / Microsoft / Apple).
# Example: admin1@example.com,admin2@example.com
ADMIN_EMAILS=you@example.com

# ============================================
# OPTIONAL: DEPLOYMENT CHECKLIST
# ============================================
# Before deploying to production:
#
# 1. Vercel Project Settings (zacharymays-site):
#    - Set: SUPABASE_SERVICE_ROLE_KEY
#    - Set: GH_DISPATCH_TOKEN (with actions:write on cultiness-spectrum repo)
#    - Set: CRON_SECRET (use strong random value)
#    - Set: INTAKE_LIVE=false initially (enable only after testing dry-run)
#    - Set: ADMIN_EMAILS (comma-separated analyst list)
#
# 2. cultiness-spectrum GitHub repo secrets (for CI/CD):
#    - SUPABASE_SERVICE_KEY (same as SUPABASE_SERVICE_ROLE_KEY)
#    - ANTHROPIC_API_KEY (for Claude scoring)
#    - OPENAI_API_KEY (for GPT scoring)
#    - GEMINI_API_KEY (for Gemini scoring)
#    - OPENROUTER_API_KEY (for fallback/free models)
#
# 3. Test the pipeline (zacharymays-site):
#    - POST /api/cron/run-intake with CRON_SECRET header (dry_run=true default)
#    - Monitor cultiness-spectrum GitHub Actions tab
#    - Verify no paid API calls were made (--dry-run enforces this)
#    - Check org_intake_proposals status doesn't change on dry-run
#
# 4. Deploy and monitor for 24-48 hours:
#    - Verify cron jobs fire at expected times (Vercel dashboard)
#    - Check CloudWatch/logs for errors
#    - Confirm network_degree values update nightly
#
# 5. Only then set INTAKE_LIVE=true (enables paid model scoring)
